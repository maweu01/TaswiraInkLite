# Taswira Space Ink v2 — Environment Variables
# Copy this file to .env and fill in values

# ─── AI Theme Generation ──────────────────────────────────
# Required ONLY for AI theme generation feature.
# Get your key at: https://console.anthropic.com
# Leave blank to disable AI (all other features work without it)
ANTHROPIC_API_KEY=

# ─── Docker / Self-Hosting ────────────────────────────────
# Port to expose the app on (default: 7200)
APP_PORT=7200
